            </div>

            <!-- แถบสรุปรวมท้ายแถวกลาง -->
            <footer class="flex justify-between items-center text-xs bg-slate-950/60 p-3 rounded-xl border border-slate-900 font-mono">
                <div class="text-slate-400 flex items-center space-x-2">
