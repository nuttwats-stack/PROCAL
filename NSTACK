    <!-- สคริปต์ระบบคำนวณหลังบ้าน (ผูกติด ID โครงสร้างเดิมของนัทครบถ้วน) -->
    <script>
        let state = {
            investCurrency: 'THB',
            buyPriceCurrency: 'THB',
            investment: 0,
            buyPrice: 0,
            volume: 0,
            currentPrice: 0,
            targetRoi: 0,
            targetPrice: 0,
            fxRate: 35.0,
            feePercent: 0.157,
            taxPercent: 7.0,
            otherExpenses: 0
        };

        const elements = {
            investment: document.getElementById('inputInvestment'),
            buyPrice: document.getElementById('inputBuyPrice'),
            volume: document.getElementById('inputVolume'),
            currentPrice: document.getElementById('inputCurrentPrice'),
            targetRoi: document.getElementById('inputTargetRoi'),
            targetRoiSlider: document.getElementById('targetRoiSlider'),
            targetPrice: document.getElementById('inputTargetPrice'),
            fxRate: document.getElementById('globalFxRate'),
            feePercent: document.getElementById('inputFeePercent'),
            taxPercent: document.getElementById('inputTaxPercent'),
            otherExpenses: document.getElementById('inputOtherExpenses'),
            labelInvestCur: document.getElementById('label-invest-cur'),
            labelBuyPriceCur: document.getElementById('label-buyPrice-cur'),
            labelCurPriceMatch: document.getElementById('label-curPrice-match'),
            labelTargetPriceMatch: document.getElementById('label-targetPrice-match'),
            otherExpensesCurrency: document.getElementById('other-expenses-currency'),
            altInvestVal: document.getElementById('alt-invest-val'),
            altBuyPriceVal: document.getElementById('alt-buyPrice-val'),
            resultCard: document.getElementById('resultCard'),
            resultRoiDisplay: document.getElementById('resultRoiDisplay'),
            resultProfitDisplay: document.getElementById('resultProfitDisplay'),
            detailNetCost: document.getElementById('detailNetCost'),
            detailNetRevenue: document.getElementById('detailNetRevenue'),
            detailTotalFees: document.getElementById('detailTotalFees'),
            detailBreakevenPrice: document.getElementById('detailBreakevenPrice'),
            detailCommFees: document.getElementById('detailCommFees'),
            detailVatFees: document.getElementById('detailVatFees'),
            detailOtherFees: document.getElementById('detailOtherFees'),
            moonProgressBar: document.getElementById('moonProgressBar'),
            distanceToMoonText: document.getElementById('distanceToMoonText')
        };

        window.onload = function() {
            updateCurrencyLabels();
            calculateFullSummary();
        };

        function formatStringWithCommas(value) {
            let cleanValue = value.replace(/,/g, '');
            if (cleanValue === '' || isNaN(cleanValue)) return cleanValue;
            let endsWithDecimal = cleanValue.endsWith('.');
            let parts = cleanValue.split('.');
            parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ',');
            if (parts.length > 1) {
                return parts[0] + '.' + parts[1].substring(0, 4);
            }
            return parts[0] + (endsWithDecimal ? '.' : '');
        }

        function handleFormattedInput(el, stateKey, calcTrigger) {
            let cursorPosition = el.selectionStart;
            let originalLen = el.value.length;
            let filteredVal = el.value.replace(/[^0-9.,-]/g, '');
            let dots = (filteredVal.match(/\./g) || []).length;
            if (dots > 1) {
                filteredVal = filteredVal.substring(0, filteredVal.lastIndexOf('.'));
            }
            let formatted = formatStringWithCommas(filteredVal);
            el.value = formatted;
            let finalLen = formatted.length;
            cursorPosition = cursorPosition + (finalLen - originalLen);
            el.setSelectionRange(cursorPosition, cursorPosition);
            
            let numericVal = parseFloat(formatted.replace(/,/g, '')) || 0;
            state[stateKey] = numericVal;

            if (stateKey === 'targetRoi') {
                elements.targetRoiSlider.value = Math.max(-200, Math.min(200, numericVal));
            }

            if (calcTrigger === 'investment' || calcTrigger === 'buyPrice' || calcTrigger === 'volume') {
                handleBuyCalculation(calcTrigger);
            } else if (calcTrigger === 'currentPrice' || calcTrigger === 'roi' || calcTrigger === 'targetPrice') {
                handleTargetCalc(calcTrigger);
            } else {
                calculateFullSummary();
            }
        }

        function handleSliderChange(val) {
            const numericRoi = parseFloat(val);
            state.targetRoi = numericRoi;
            elements.targetRoi.value = formatStringWithCommas(numericRoi.toFixed(2));
            handleTargetCalc('roi');
        }

        function handleDirectFxInput(el) {
            state.fxRate = parseFloat(el.value) || 35.0;
            calculateFullSummary();
        }

        function setCurrency(target, currency) {
            const fx = state.fxRate;
            if (target === 'invest') {
                state.investCurrency = currency;
                document.getElementById('btn-invest-thb').className = currency === 'THB' ? 'px-1.5 rounded bg-yellow-500 text-slate-950 font-bold' : 'px-1.5 rounded text-slate-400';
                document.getElementById('btn-invest-usd').className = currency === 'USD' ? 'px-1.5 rounded bg-yellow-500 text-slate-950 font-bold' : 'px-1.5 rounded text-slate-400';
            } else if (target === 'buyPrice') {
                state.buyPriceCurrency = currency;
                document.getElementById('btn-buyPrice-thb').className = currency === 'THB' ? 'px-1.5 rounded bg-yellow-500 text-slate-950 font-bold' : 'px-1.5 rounded text-slate-400';
                document.getElementById('btn-buyPrice-usd').className = currency === 'USD' ? 'px-1.5 rounded bg-yellow-500 text-slate-950 font-bold' : 'px-1.5 rounded text-slate-400';
            }
            updateCurrencyLabels();
            handleBuyCalculation('currency_switch');
        }

        function updateCurrencyLabels() {
            if(elements.labelInvestCur) elements.labelInvestCur.textContent = state.investCurrency;
            if(elements.labelBuyPriceCur) elements.labelBuyPriceCur.textContent = state.buyPriceCurrency;
            elements.labelCurPriceMatch.textContent = state.buyPriceCurrency;
            elements.labelTargetPriceMatch.textContent = state.buyPriceCurrency;
            elements.otherExpensesCurrency.textContent = state.buyPriceCurrency;
        }

        function applyFeePreset(val) {
            elements.feePercent.value = val;
            state.feePercent = val;
            calculateFullSummary();
        }

        function setQuickRoi(percentage) {
            elements.targetRoi.value = percentage;
            elements.targetRoiSlider.value = percentage;
            state.targetRoi = percentage;
            handleTargetCalc('roi');
        }

        function handleBuyCalculation(changedField) {
            const fx = state.fxRate;
            let investmentInBuyPriceCurrency = state.investment;
            if (state.investCurrency !== state.buyPriceCurrency) {
                investmentInBuyPriceCurrency = (state.investCurrency === 'THB') ? (state.investment / fx) : (state.investment * fx);
            }

            if (changedField === 'investment' && state.buyPrice > 0) {
                state.volume = Math.floor(investmentInBuyPriceCurrency / state.buyPrice);
                elements.volume.value = state.volume > 0 ? formatStringWithCommas(state.volume.toString()) : "";
            } else if (changedField === 'buyPrice' && state.investment > 0 && state.buyPrice > 0) {
                state.volume = Math.floor(investmentInBuyPriceCurrency / state.buyPrice);
                elements.volume.value = state.volume > 0 ? formatStringWithCommas(state.volume.toString()) : "";
            } else if (changedField === 'volume' && state.volume > 0 && state.buyPrice > 0) {
                let calculatedInvest = state.buyPrice * state.volume;
                state.investment = (state.investCurrency !== state.buyPriceCurrency) ? ((state.investCurrency === 'THB') ? calculatedInvest * fx : calculatedInvest / fx) : calculatedInvest;
                elements.investment.value = formatStringWithCommas(state.investment.toFixed(2));
            }
            updateAlternativeCurrencyTexts(fx);
            calculateFullSummary();
        }

        function updateAlternativeCurrencyTexts(fx) {
            elements.altInvestVal.textContent = state.investment > 0 ? `≃ ${(state.investCurrency === 'THB' ? state.investment / fx : state.investment * fx).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})} ${state.investCurrency === 'THB' ? 'USD' : 'THB'}` : '≃ 0.00 USD';
            elements.altBuyPriceVal.textContent = state.buyPrice > 0 ? `≃ ${(state.buyPriceCurrency === 'THB' ? state.buyPrice / fx : state.buyPrice * fx).toLocaleString(undefined, {minimumFractionDigits: 4, maximumFractionDigits: 4})} ${state.buyPriceCurrency === 'THB' ? 'USD' : 'THB'}` : '≃ 0.00 USD';
        }

        function handleTargetCalc(changedField) {
            if (state.buyPrice <= 0) return;
            if (changedField === 'currentPrice') {
                state.targetRoi = ((state.currentPrice - state.buyPrice) / state.buyPrice) * 100;
                elements.targetRoi.value = formatStringWithCommas(state.targetRoi.toFixed(2));
                elements.targetRoiSlider.value = Math.max(-200, Math.min(200, state.targetRoi));
                state.targetPrice = state.currentPrice;
                elements.targetPrice.value = formatStringWithCommas(state.targetPrice.toFixed(4));
            } else if (changedField === 'roi') {
                state.targetPrice = state.buyPrice * (1 + (state.targetRoi / 100));
                elements.targetPrice.value = formatStringWithCommas(state.targetPrice.toFixed(4));
                state.currentPrice = state.targetPrice;
                elements.currentPrice.value = formatStringWithCommas(state.currentPrice.toFixed(4));
            } else if (changedField === 'targetPrice') {
                state.targetRoi = ((state.targetPrice - state.buyPrice) / state.buyPrice) * 100;
                elements.targetRoi.value = formatStringWithCommas(state.targetRoi.toFixed(2));
                elements.targetRoiSlider.value = Math.max(-200, Math.min(200, state.targetRoi));
                state.currentPrice = state.targetPrice;
                elements.currentPrice.value = formatStringWithCommas(state.currentPrice.toFixed(4));
            }
            calculateFullSummary();
        }

        function calculateFullSummary() {
            const feePercent = state.feePercent / 100;
            const taxPercent = state.taxPercent / 100;
            if (state.buyPrice <= 0 || state.volume <= 0) {
                clearOutputs();
                return;
            }
            const grossBuy = state.buyPrice * state.volume;
            const buyComm = grossBuy * feePercent;
            const buyVat = buyComm * taxPercent;
            const totalCost = grossBuy + buyComm + buyVat + state.otherExpenses;

            const grossSell = state.currentPrice * state.volume;
            const sellComm = grossSell * feePercent;
            const sellVat = sellComm * taxPercent;
            const totalRevenue = grossSell - sellComm - sellVat - state.otherExpenses;

            const netProfit = totalRevenue - totalCost;
            const netRoi = totalCost > 0 ? (netProfit / totalCost) * 100 : 0;
            const feeRateWithTax = feePercent * (1 + taxPercent);
            const breakevenPrice = (totalCost + state.otherExpenses) / (state.volume * (1 - feeRateWithTax));

            elements.detailNetCost.textContent = totalCost.toLocaleString(undefined, {maximumFractionDigits:2});
            elements.detailNetRevenue.textContent = totalRevenue.toLocaleString(undefined, {maximumFractionDigits:2});
            elements.detailTotalFees.textContent = `${(buyComm+buyVat+sellComm+sellVat).toLocaleString(undefined, {maximumFractionDigits:2})} ${state.buyPriceCurrency}`;
            elements.detailBreakevenPrice.textContent = `${breakevenPrice.toLocaleString(undefined, {maximumFractionDigits:4})} ${state.buyPriceCurrency}`;
            elements.detailCommFees.textContent = `${(buyComm+sellComm).toLocaleString(undefined, {maximumFractionDigits:2})} ${state.buyPriceCurrency}`;
            elements.detailVatFees.textContent = `${(buyVat+sellVat).toLocaleString(undefined, {maximumFractionDigits:2})} ${state.buyPriceCurrency}`;
            elements.detailOtherFees.textContent = `${(state.otherExpenses * 2).toLocaleString(undefined, {maximumFractionDigits:2})} ${state.buyPriceCurrency}`;

            elements.resultRoiDisplay.textContent = `${netRoi >= 0 ? '+' : ''}${netRoi.toFixed(2)}%`;
            elements.resultProfitDisplay.textContent = `${netProfit >= 0 ? '+' : ''}${netProfit.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2})} ${state.buyPriceCurrency}`;

            if (netProfit > 0) {
                elements.resultRoiDisplay.className = "text-2xl font-black font-mono text-emerald-400";
            } else if (netProfit < 0) {
                elements.resultRoiDisplay.className = "text-2xl font-black font-mono text-rose-400";
            } else {
                elements.resultRoiDisplay.className = "text-2xl font-black font-mono text-slate-300";
            }

            let progress = 50 + (netRoi / 4.0);
            elements.moonProgressBar.style.width = `${Math.max(1, Math.min(99, progress))}%`;
            elements.distanceToMoonText.textContent = netRoi >= 20 ? "ถึงเป้าหมายดวงจันทร์แล้ว! 🌟" : (netRoi > 0 ? "พุ่งยานอวกาศ! ⚡" : (netRoi === 0 ? "เตรียมตัวปล่อยยาน" : "ติดดอย/แรงโน้มถ่วงดึงดูด 📉"));
        }

        function clearOutputs() {
            elements.resultRoiDisplay.textContent = "0.00%";
            elements.resultProfitDisplay.textContent = `0.00 ${state.buyPriceCurrency}`;
            elements.moonProgressBar.style.width = "50%";
            elements.distanceToMoonText.textContent = "เตรียมตัวปล่อยยาน";
        }

        function resetCalculator() {
            location.reload();
        }
    </script>
</body>
</html>
