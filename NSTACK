    <div class="fixed bottom-20 left-1/4 text-3xl opacity-5 space-rocket-float pointer-events-none hidden xl:block" style="animation-delay: -3s;">🚀</div>

    <!-- Container หลักจัด Layout 3 คอลัมน์แบบหน้าต่าง Canva -->
