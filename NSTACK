<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- 1. เปลี่ยนชื่อหน้าเว็บตามสั่ง -->
    <title>Mission to the moon</title>
    <!-- นำเข้า Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* 2. ลูกเล่นนีออนสีขาววิ่งรอบกรอบช้าๆ แบบหรูหรา */
        @keyframes neon-dance {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        .running-neon {
            position: relative;
            border: 1px solid transparent;
            background: linear-gradient(#0e1326, #0e1326) padding-box,
                        linear-gradient(90deg, rgba(255,255,255,0.08), rgba(255,255,255,0.6), rgba(255,255,255,0.08)) border-box;
            background-size: 200% 100%;
            animation: neon-dance 10s linear infinite;
        }

        /* 3. กราฟิกจรวดบินลอยเบาๆ เพลินๆ ในพื้นหลัง */
        @keyframes rocket-float {
            0%, 100% { transform: translateY(0) translateX(0) rotate(45deg); }
            50% { transform: translateY(-15px) translateX(10px) rotate(48deg); }
        }
        .space-rocket-float {
            animation: rocket-float 6s ease-in-out infinite;
        }

        /* รีเซ็ตดีไซน์แอนิเมชันสำหรับแถบความคืบหน้าจรวดวิ่งไปดวงจันทร์ */
        @keyframes pulse-glow {
            0%, 100% { opacity: 0.6; }
            50% { opacity: 1; }
        }
        .glow-pulse { animation: pulse-glow 2s infinite; }

        input::-webkit-outer-spin-button, input::-webkit-inner-spin-button {
            -webkit-appearance: none; margin: 0;
        }
    </style>
</head>
<!-- 4. ปรับขนาดควบคุมให้อยู่ในหน้าเดียวบนจอ Desktop (h-screen / overflow-hidden) -->
<body class="bg-[#070a14] text-slate-100 xl:h-screen xl:overflow-hidden font-sans antialiased flex flex-col justify-between p-3 select-none">

    <!-- กราฟิกจรวดลอยหลังเว็บเพลินๆ -->
